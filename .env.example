# Firebase configuration (para modo Cloud)
# Obtener desde: https://console.firebase.google.com/
# Settings del proyecto → General → Your apps → Web app → Config
#
# IMPORTANTE: Estas variables son PÚBLICAS (van al frontend).
# La seguridad real se maneja con las reglas de Firestore y
# los scopes de Google OAuth, no escondiendo estas keys.
#
# Si estas variables NO están seteadas, la app corre 100% en modo offline.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_APP_ID=
